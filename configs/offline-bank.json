{
  "agent": {
    "model": "local-openai/qwen2.5-72b-instruct"
  },
  "models": {
    "providers": {
      "local-openai": {
        "baseUrl": "http://127.0.0.1:8000/v1",
        "apiKey": "sk-dummy",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen2.5-72b-instruct",
            "name": "Qwen2.5 72B Instruct",
            "api": "openai-completions",
            "reasoning": true,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "plugins": {
    "enabled": true,
    "allow": ["memory-core", "memory-lancedb"],
    "deny": ["*"]
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "off"
      }
    }
  },
  "tools": {
    "profile": "minimal",
    "allow": ["bash", "read", "write", "edit"],
    "deny": ["*"],
    "exec": {
      "security": "allowlist",
      "safeBins": ["python", "python3", "node", "npm", "powershell", "pwsh"],
      "pathPrepend": ["D:\\bank\\scripts", "D:\\bank\\tools"],
      "ask": "off"
    },
    "fs": {
      "workspaceOnly": true
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "127.0.0.1",
    "port": 18789,
    "auth": {
      "mode": "none"
    }
  },
  "update": {
    "checkOnStart": false,
    "auto": {
      "enabled": false
    }
  },
  "logging": {
    "level": "info"
  },
  "web": {
    "search": {
      "enabled": false
    }
  },
  "browser": {
    "enabled": false
  },
  "canvasHost": {
    "enabled": false
  },
  "audio": {
    "enabled": false
  },
  "media": {
    "preserveFilenames": false
  }
}
